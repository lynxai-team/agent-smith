{
  "name": "@agent-smith/wscli",
  "version": "0.0.5",
  "description": "An websockets client for the Agent Smith server",
  "repository": "https://github.com/synw/agent-smith",
  "scripts": {
    "buildrl": "rm -rf dist/* && rollup -c",
    "build": "rm -rf dist/* && tsc",
    "docs": "typedoc --entryPointStrategy expand"
  },
  "devDependencies": {
    "@agent-smith/types": "file:../types",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.6.0",
    "restmix": "^0.6.1",
    "rollup": "^4.60.2",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
  },
  "files": [
    "dist"
  ],
  "module": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/main.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "license": "MIT",
  "dependencies": {
    "@vue/reactivity": "^3.5.33",
    "reconnecting-websocket": "^4.4.0"
  }
}
